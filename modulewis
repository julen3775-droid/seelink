void SetProgress(int pct, const wchar_t* msg)
{
    if (g_hProgress) SendMessageW(g_hProgress, PBM_SETPOS, pct, 0);
    if (g_hStatus)   SetWindowTextW(g_hStatus, msg);
}

// Write the uninstall registry entry
void RegisterUninstall()
{
    HKEY hk;
    if (RegCreateKeyExW(HKEY_LOCAL_MACHINE, UNINSTALL_KEY, 0, NULL,
                        REG_OPTION_NON_VOLATILE, KEY_WRITE | KEY_WOW64_32KEY,
                        NULL, &hk, NULL) != ERROR_SUCCESS) return;

    std::wstring exe = g_installPath + L"\\SeeLink.exe";
    std::wstring uninst = g_installPath + L"\\uninstall.exe";

    auto ws = [&](const wchar_t* name, const std::wstring& val) {
        RegSetValueExW(hk, name, 0, REG_SZ,
            (const BYTE*)val.c_str(), (DWORD)((val.size()+1)*sizeof(wchar_t)));
    };
    ws(L"DisplayName",          APP_NAME L" " APP_VERSION);
    ws(L"DisplayVersion",       APP_VERSION);
    ws(L"Publisher",            PUBLISHER);
    ws(L"InstallLocation",      g_installPath);
    ws(L"UninstallString",      uninst);
    ws(L"DisplayIcon",          exe);

    RegCloseKey(hk);
}

// Create a .lnk shortcut using IShellLink
void CreateShortcut(const std::wstring& linkPath, const std::wstring& targetPath,
                    const std::wstring& workDir, const std::wstring& desc)
{
    CoInitialize(NULL);
    IShellLinkW* psl = NULL;
    if (SUCCEEDED(CoCreateInstance(CLSID_ShellLink, NULL, CLSCTX_INPROC_SERVER,
                                   IID_IShellLinkW, (void**)&psl)))
    {
        psl->SetPath(targetPath.c_str());
        psl->SetWorkingDirectory(workDir.c_str());
        psl->SetDescription(desc.c_str());

        IPersistFile* ppf = NULL;
        if (SUCCEEDED(psl->QueryInterface(IID_IPersistFile, (void**)&ppf))) {
            ppf->Save(linkPath.c_str(), TRUE);
            ppf->Release();
        }
        psl->Release();
    }
    CoUninitialize();
}

DWORD WINAPI InstallThread(LPVOID)
{
    // 1. Create install directory
    SetProgress(5, L"Creating installation directory...");
    if (!CreateDirectoryW(g_installPath.c_str(), NULL)) {
        if (GetLastError() != ERROR_ALREADY_EXISTS) {
            g_installFailed = true;
            PostMessageW(g_hWnd, WM_COMMAND, MAKEWPARAM(0, BN_CLICKED), 0);
            return 1;
        }
    }
    Sleep(300);

    // 2. Copy main executable (in a real build you'd extract from resources)
    SetProgress(20, L"Copying SeeLink files...");
    wchar_t selfPath[MAX_PATH];
    GetModuleFileNameW(NULL, selfPath, MAX_PATH);
    std::wstring destExe = g_installPath + L"\\SeeLink.exe";
    // For now copy the installer itself as placeholder; replace with your actual binary
    CopyFileW(selfPath, destExe.c_str(), FALSE);
    Sleep(400);

    // 3. Write version file
    SetProgress(40, L"Writing configuration...");
    std::wstring cfgPath = g_installPath + L"\\version.txt";
    HANDLE hf = CreateFileW(cfgPath.c_str(), GENERIC_WRITE, 0, NULL,
                            CREATE_ALWAYS, FILE_ATTRIBUTE_NORMAL, NULL);
    if (hf != INVALID_HANDLE_VALUE) {
        const char* ver = "SeeLink 1.0.0\r\nJulentics Industries\r\n";
        DWORD written;
        WriteFile(hf, ver, (DWORD)strlen(ver), &written, NULL);
        CloseHandle(hf);
    }
    Sleep(300);

    // 4. Desktop shortcut
    if (g_desktopShortcut) {
        SetProgress(55, L"Creating desktop shortcut...");
        wchar_t desktopPath[MAX_PATH];
        SHGetFolderPathW(NULL, CSIDL_COMMON_DESKTOPDIRECTORY, NULL,
                         SHGFP_TYPE_CURRENT, desktopPath);
        std::wstring lnk = std::wstring(desktopPath) + L"\\SeeLink.lnk";
        CreateShortcut(lnk, destExe, g_installPath, L"SeeLink USB File Manager");
        Sleep(200);
    }

    // 5. Start Menu
    if (g_startMenuShortcut) {
        SetProgress(70, L"Adding to Start Menu...");
        wchar_t smPath[MAX_PATH];
        SHGetFolderPathW(NULL, CSIDL_COMMON_PROGRAMS, NULL,
                         SHGFP_TYPE_CURRENT, smPath);
        std::wstring folder = std::wstring(smPath) + L"\\SeeLink";
        CreateDirectoryW(folder.c_str(), NULL);
        std::wstring lnk = folder + L"\\SeeLink.lnk";
        CreateShortcut(lnk, destExe, g_installPath, L"SeeLink USB File Manager");
        Sleep(200);
    }

    // 6. Registry uninstall entry
    SetProgress(85, L"Registering uninstall entry...");
    RegisterUninstall();
    Sleep(300);

    // 7. Done
    SetProgress(100, L"Installation complete!");
    Sleep(400);

    g_installDone = true;
    // Signal main thread to advance to FINISH page
    PostMessageW(g_hWnd, WM_USER + 1, 0, 0);
    return 0;
}

// ─── Page navigation ─────────────────────────────────────────────────────────

void ReadPageOptions()
{
    if (g_currentPage == PAGE_PATH) {
        wchar_t buf[MAX_PATH] = {};
        HWND hEdit = GetDlgItem(g_hWnd, ID_EDIT_PATH);
        if (hEdit) GetWindowTextW(hEdit, buf, MAX_PATH);
        if (wcslen(buf) > 0) g_installPath = buf;

        HWND hChkD = GetDlgItem(g_hWnd, ID_CHK_DESKTOP);
        HWND hChkS = GetDlgItem(g_hWnd, ID_CHK_STARTMENU);
        if (hChkD) g_desktopShortcut   = (SendMessageW(hChkD, BM_GETCHECK, 0, 0) == BST_CHECKED);
        if (hChkS) g_startMenuShortcut = (SendMessageW(hChkS, BM_GETCHECK, 0, 0) == BST_CHECKED);
    }
}

void UpdateNavButtons()
{
    HWND hNext   = GetDlgItem(g_hWnd, ID_BTN_NEXT);
    HWND hBack   = GetDlgItem(g_hWnd, ID_BTN_BACK);
    HWND hCancel = GetDlgItem(g_hWnd, ID_BTN_CANCEL);

    switch (g_currentPage) {
    case PAGE_WELCOME:
        SetWindowTextW(hNext, L"Next >");
        EnableWindow(hBack, FALSE);
        EnableWindow(hNext, TRUE);
        EnableWindow(hCancel, TRUE);
        break;
    case PAGE_PATH:
        SetWindowTextW(hNext, L"Install");
        EnableWindow(hBack, TRUE);
        EnableWindow(hNext, TRUE);
        EnableWindow(hCancel, TRUE);
        break;
    case PAGE_INSTALL:
        SetWindowTextW(hNext, L"Next >");
        EnableWindow(hBack, FALSE);
        EnableWindow(hNext, FALSE);
        EnableWindow(hCancel, FALSE);
        break;
    case PAGE_FINISH:
        SetWindowTextW(hNext, L"Finish");
        EnableWindow(hBack, FALSE);
        EnableWindow(hNext, TRUE);
        EnableWindow(hCancel, FALSE);
        break;
    }
}

void ShowPage(int page)
{
    ClearPageControls();
    g_currentPage = page;
    InvalidateRect(g_hWnd, NULL, TRUE);

    switch (page) {
    case PAGE_WELCOME: BuildPageWelcome(); break;
    case PAGE_PATH:    BuildPagePath();    break;
    case PAGE_INSTALL:
        BuildPageInstall();
        UpdateNavButtons();
        // Kick off install thread
        CreateThread(NULL, 0, InstallThread, NULL, 0, NULL);
        return;  // nav buttons updated inside
    case PAGE_FINISH:  BuildPageFinish();  break;
    }
    UpdateNavButtons();
}

// ─── Window Procedure ────────────────────────────────────────────────────────

LRESULT CALLBACK WndProc(HWND hwnd, UINT msg, WPARAM wp, LPARAM lp)
{
    switch (msg)
    {
    case WM_CREATE:
    {
        // Fonts
        g_hFontTitle  = CreateFontW(28, 0, 0, 0, FW_BOLD, FALSE, FALSE, FALSE,
                            DEFAULT_CHARSET, OUT_DEFAULT_PRECIS, CLIP_DEFAULT_PRECIS,
                            CLEARTYPE_QUALITY, DEFAULT_PITCH, L"Segoe UI");
        g_hFontNormal = CreateFontW(15, 0, 0, 0, FW_NORMAL, FALSE, FALSE, FALSE,
                            DEFAULT_CHARSET, OUT_DEFAULT_PRECIS, CLIP_DEFAULT_PRECIS,
                            CLEARTYPE_QUALITY, DEFAULT_PITCH, L"Segoe UI");
        g_hFontMono   = CreateFontW(14, 0, 0, 0, FW_NORMAL, FALSE, FALSE, FALSE,
                            DEFAULT_CHARSET, OUT_DEFAULT_PRECIS, CLIP_DEFAULT_PRECIS,
                            CLEARTYPE_QUALITY, FIXED_PITCH,   L"Consolas");

        g_hBrushBg   = CreateSolidBrush(CLR_BG);
        g_hBrushSurf = CreateSolidBrush(CLR_SURFACE);

        g_installPath = GetDefaultInstallPath();

        // Bottom nav bar buttons (persistent, not per-page)
        HWND hCancel = CreateWindowW(L"BUTTON", L"Cancel",
            WS_CHILD | WS_VISIBLE | BS_PUSHBUTTON,
            20, WIZ_H - 54, 90, 32, hwnd, (HMENU)ID_BTN_CANCEL, g_hInst, NULL);
        SendMessageW(hCancel, WM_SETFONT, (WPARAM)g_hFontNormal, TRUE);

        HWND hBack = CreateWindowW(L"BUTTON", L"< Back",
            WS_CHILD | WS_VISIBLE | BS_PUSHBUTTON,
            WIZ_W - 220, WIZ_H - 54, 90, 32, hwnd, (HMENU)ID_BTN_BACK, g_hInst, NULL);
        SendMessageW(hBack, WM_SETFONT, (WPARAM)g_hFontNormal, TRUE);

        HWND hNext = CreateWindowW(L"BUTTON", L"Next >",
            WS_CHILD | WS_VISIBLE | BS_PUSHBUTTON | BS_DEFPUSHBUTTON,
            WIZ_W - 120, WIZ_H - 54, 100, 32, hwnd, (HMENU)ID_BTN_NEXT, g_hInst, NULL);
        SendMessageW(hNext, WM_SETFONT, (WPARAM)g_hFontNormal, TRUE);

        ShowPage(PAGE_WELCOME);
        break;
    }

    // Install thread finished → go to finish page
    case WM_USER + 1:
        ShowPage(PAGE_FINISH);
        break;

    case WM_CTLCOLORSTATIC:
    {
        HDC hdc = (HDC)wp;
        HWND hCtrl = (HWND)lp;
        COLORREF textColor = (COLORREF)GetWindowLongPtrW(hCtrl, GWLP_USERDATA);
        if (textColor == 0) textColor = CLR_TEXT;
        SetTextColor(hdc, textColor);
        SetBkMode(hdc, TRANSPARENT);
        return (LRESULT)g_hBrushBg;
    }

    case WM_CTLCOLORBTN:
    {
        HDC hdc = (HDC)wp;
        SetBkMode(hdc, TRANSPARENT);
        return (LRESULT)g_hBrushBg;
    }

    case WM_CTLCOLOREDIT:
    {
        HDC hdc = (HDC)wp;
        SetTextColor(hdc, CLR_TEXT);
        SetBkColor(hdc, CLR_BORDER);
        return (LRESULT)CreateSolidBrush(CLR_BORDER);
    }

    case WM_ERASEBKGND:
    {
        HDC hdc = (HDC)wp;
        RECT rc;
        GetClientRect(hwnd, &rc);
        FillRect(hdc, &rc, g_hBrushBg);

        // Draw top banner
        RECT banner = { 0, 0, WIZ_W, 48 };
        FillRect(hdc, &banner, g_hBrushSurf);

        // Bottom bar
        RECT bar = { 0, WIZ_H - 64, WIZ_W, WIZ_H };
        FillRect(hdc, &bar, g_hBrushSurf);

        // Divider lines
        HPEN pen = CreatePen(PS_SOLID, 1, CLR_BORDER);
        HPEN old = (HPEN)SelectObject(hdc, pen);
        MoveToEx(hdc, 0, 48, NULL); LineTo(hdc, WIZ_W, 48);
        MoveToEx(hdc, 0, WIZ_H - 64, NULL); LineTo(hdc, WIZ_W, WIZ_H - 64);
        SelectObject(hdc, old);
        DeleteObject(pen);

        // Top-left accent dot
        HBRUSH accentBrush = CreateSolidBrush(CLR_ACCENT);
        RECT dot = { 12, 16, 18, 32 };
        FillRect(hdc, &dot, accentBrush);
        DeleteObject(accentBrush);

        return 1;
    }

    case WM_PAINT:
    {
        PAINTSTRUCT ps;
        HDC hdc = BeginPaint(hwnd, &ps);
        // App title in banner
        SelectObject(hdc, g_hFontNormal);
        SetTextColor(hdc, CLR_ACCENT);
        SetBkMode(hdc, TRANSPARENT);
        TextOutW(hdc, 28, 14, L"SeeLink Setup", 13);
        // Page indicator
        wchar_t pageStr[32];
        wsprintfW(pageStr, L"Step %d of 4", g_currentPage + 1);
        SetTextColor(hdc, CLR_MUTED);
        RECT pr = { WIZ_W - 120, 14, WIZ_W - 16, 34 };
        DrawTextW(hdc, pageStr, -1, &pr, DT_RIGHT);
        EndPaint(hwnd, &ps);
        break;
    }

    case WM_COMMAND:
    {
        int id = LOWORD(wp);

        if (id == ID_BTN_CANCEL) {
            if (MessageBoxW(hwnd, L"Are you sure you want to cancel the installation?",
                            L"Cancel Setup", MB_YESNO | MB_ICONQUESTION) == IDYES)
                DestroyWindow(hwnd);
        }
        else if (id == ID_BTN_NEXT) {
            ReadPageOptions();
            if (g_currentPage == PAGE_FINISH) {
                DestroyWindow(hwnd);
            } else {
                ShowPage(g_currentPage + 1);
            }
        }
        else if (id == ID_BTN_BACK) {
            if (g_currentPage > PAGE_WELCOME)
                ShowPage(g_currentPage - 1);
        }
        else if (id == ID_BTN_BROWSE) {
            // Folder picker (works Win XP+)
            BROWSEINFOW bi = {};
            bi.hwndOwner = hwnd;
            bi.lpszTitle = L"Select installation folder:";
            bi.ulFlags   = BIF_RETURNONLYFSDIRS | BIF_NEWDIALOGSTYLE;
            LPITEMIDLIST pidl = SHBrowseForFolderW(&bi);
            if (pidl) {
                wchar_t path[MAX_PATH];
                if (SHGetPathFromIDListW(pidl, path)) {
                    g_installPath = std::wstring(path) + L"\\" APP_NAME;
                    HWND hEdit = GetDlgItem(hwnd, ID_EDIT_PATH);
                    if (hEdit) SetWindowTextW(hEdit, g_installPath.c_str());
                }
                CoTaskMemFree(pidl);
            }
        }
        break;
    }

    case WM_DESTROY:
        DeleteObject(g_hFontTitle);
        DeleteObject(g_hFontNormal);
        DeleteObject(g_hFontMono);
        DeleteObject(g_hBrushBg);
        DeleteObject(g_hBrushSurf);
        PostQuitMessage(0);
        break;

    default:
        return DefWindowProcW(hwnd, msg, wp, lp);
    }
    return 0;
}

// ─── WinMain ─────────────────────────────────────────────────────────────────

int WINAPI WinMain(HINSTANCE hInst, HINSTANCE, LPSTR, int)
{
    g_hInst = hInst;

    // Enable visual styles (ComCtl32 v6)
    INITCOMMONCONTROLSEX icc = { sizeof(icc), ICC_PROGRESS_CLASS | ICC_WIN95_CLASSES };
    InitCommonControlsEx(&icc);

    // Register window class
    WNDCLASSEXW wc = {};
    wc.cbSize        = sizeof(wc);
    wc.lpfnWndProc   = WndProc;
    wc.hInstance     = hInst;
    wc.hCursor       = LoadCursorW(NULL, IDC_ARROW);
    wc.hbrBackground = NULL;   // handled in WM_ERASEBKGND
    wc.lpszClassName = L"SeeLinkInstaller";
    wc.hIcon         = LoadIconW(NULL, IDI_APPLICATION);
    RegisterClassExW(&wc);

    // Center on screen
    int sw = GetSystemMetrics(SM_CXSCREEN);
    int sh = GetSystemMetrics(SM_CYSCREEN);
    int wx = (sw - WIZ_W) / 2;
    int wy = (sh - WIZ_H) / 2;

    g_hWnd = CreateWindowExW(
        WS_EX_APPWINDOW,
        L"SeeLinkInstaller",
        L"SeeLink " APP_VERSION L" Setup",
        WS_OVERLAPPED | WS_CAPTION | WS_SYSMENU | WS_MINIMIZEBOX,
        wx, wy, WIZ_W, WIZ_H,
        NULL, NULL, hInst, NULL
    );

    ShowWindow(g_hWnd, SW_SHOW);
    UpdateWindow(g_hWnd);

    MSG msg;
    while (GetMessageW(&msg, NULL, 0, 0)) {
        TranslateMessage(&msg);
        DispatchMessageW(&msg);
    }
    return (int)msg.wParam;
}