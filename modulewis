// Detect if running on a 64-bit OS (even from a 32-bit process)
bool IsOS64Bit()
{
#if defined(_WIN64)
    return true;
#else
    typedef BOOL (WINAPI *LPFN_ISWOW64PROCESS)(HANDLE, PBOOL);
    LPFN_ISWOW64PROCESS fn = (LPFN_ISWOW64PROCESS)
        GetProcAddress(GetModuleHandleW(L"kernel32"), "IsWow64Process");
    if (fn) {
        BOOL wow64 = FALSE;
        fn(GetCurrentProcess(), &wow64);
        return wow64 == TRUE;
    }
    return false;
#endif
}

std::wstring GetDefaultInstallPath()
{
    wchar_t buf[MAX_PATH] = {};
    // SHGetFolderPath works on Win XP+; use CSIDL_PROGRAM_FILES for native bitness
    // For a 32-bit installer on 64-bit OS we want Program Files, not Program Files (x86)
    if (IsOS64Bit()) {
        // ExpandEnvironmentStrings for ProgramW6432 gives the real 64-bit folder
        ExpandEnvironmentStringsW(L"%ProgramW6432%", buf, MAX_PATH);
    } else {
        SHGetFolderPathW(NULL, CSIDL_PROGRAM_FILES, NULL, SHGFP_TYPE_CURRENT, buf);
    }
    return std::wstring(buf) + L"\\" APP_NAME;
}

void ClearPageControls()
{
    for (HWND h : g_pageControls) DestroyWindow(h);
    g_pageControls.clear();
    g_hProgress = NULL;
    g_hStatus   = NULL;
}

HWND MakeLabel(HWND parent, const wchar_t* text, int x, int y, int w, int h,
               HFONT font, COLORREF color = CLR_TEXT, DWORD style = 0)
{
    HWND hw = CreateWindowW(L"STATIC", text,
        WS_CHILD | WS_VISIBLE | SS_LEFT | style,
        x, y, w, h, parent, NULL, g_hInst, NULL);
    SendMessageW(hw, WM_SETFONT, (WPARAM)font, TRUE);
    SetWindowLongPtrW(hw, GWLP_USERDATA, (LONG_PTR)color);
    g_pageControls.push_back(hw);
    return hw;
}

HWND MakeButton(HWND parent, const wchar_t* text, int id, int x, int y, int w, int h)
{
    HWND hw = CreateWindowW(L"BUTTON", text,
        WS_CHILD | WS_VISIBLE | BS_PUSHBUTTON,
        x, y, w, h, parent, (HMENU)(LONG_PTR)id, g_hInst, NULL);
    SendMessageW(hw, WM_SETFONT, (WPARAM)g_hFontNormal, TRUE);
    g_pageControls.push_back(hw);
    return hw;
}

HWND MakeCheckbox(HWND parent, const wchar_t* text, int id, int x, int y, int w, int h, bool checked)
{
    HWND hw = CreateWindowW(L"BUTTON", text,
        WS_CHILD | WS_VISIBLE | BS_AUTOCHECKBOX,
        x, y, w, h, parent, (HMENU)(LONG_PTR)id, g_hInst, NULL);
    SendMessageW(hw, WM_SETFONT, (WPARAM)g_hFontNormal, TRUE);
    SendMessageW(hw, BM_SETCHECK, checked ? BST_CHECKED : BST_UNCHECKED, 0);
    g_pageControls.push_back(hw);
    return hw;
}

